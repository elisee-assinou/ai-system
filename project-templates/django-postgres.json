{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "$HOME/ai-system/architecture/context.md",
    "$HOME/ai-system/rules/frontend.md",
    "$HOME/ai-system/rules/django.md"
  ],
  "permission": {
    "bash": {
      "python manage.py test": "allow",
      "python manage.py runserver": "allow",
      "python manage.py migrate": "allow",
      "python manage.py makemigrations": "allow",
      "ruff *": "allow",
      "git status": "allow",
      "git diff": "allow",
      "git log *": "allow",
      "*": "ask"
    },
    "edit": "allow",
    "read": "allow"
  }
}
