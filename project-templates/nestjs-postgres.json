{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "$HOME/ai-system/architecture/context.md",
    "$HOME/ai-system/rules/frontend.md",
    "$HOME/ai-system/rules/nestJs.md"
  ],
  "permission": {
    "bash": {
      "npm test": "allow",
      "npm run dev": "allow",
      "npm run typecheck": "allow",
      "npm run lint": "allow",
      "git status": "allow",
      "git diff": "allow",
      "git log *": "allow",
      "*": "ask"
    },
    "edit": "allow",
    "read": "allow"
  }
}
